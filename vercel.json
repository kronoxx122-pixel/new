{
  "builds": [
    {
      "src": "**/*.php",
      "use": "vercel-php@0.7.3"
    },
    {
      "src": "**/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.js",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.png",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.jpg",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.svg",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.webp",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.ico",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.gif",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.woff",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.woff2",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.ttf",
      "use": "@vercel/static"
    }
  ]
}
